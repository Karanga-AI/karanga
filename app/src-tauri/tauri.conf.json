{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Karanga",
  "version": "0.0.0",
  "identifier": "dev.karanga.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Karanga",
        "width": 1040,
        "height": 760,
        "minWidth": 600,
        "minHeight": 440,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
